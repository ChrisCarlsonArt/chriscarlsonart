<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  {%- set pageTitle = title if title else site.title -%}
  {%- set metaTitle = (title + " | " + site.name) if title else site.title -%}
  {%- set metaDesc = description if description else site.description -%}
  {%- set canonical = (page.url | absoluteUrl(site.url)) -%}
  {%- set ogImg = (ogImage if ogImage else site.ogImage) | absoluteUrl(site.url) -%}

  <title>{{ metaTitle }}</title>
  <meta name="description" content="{{ metaDesc }}">
  <link rel="canonical" href="{{ canonical }}">
  <meta name="author" content="{{ site.author }}">
  <meta name="robots" content="index, follow, max-image-preview:large">

  <!-- Open Graph -->
  <meta property="og:type" content="{{ ogType if ogType else "website" }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:title" content="{{ metaTitle }}">
  <meta property="og:description" content="{{ metaDesc }}">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:image" content="{{ ogImg }}">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ metaTitle }}">
  <meta name="twitter:description" content="{{ metaDesc }}">
  <meta name="twitter:image" content="{{ ogImg }}">

  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32">
  <link rel="icon" href="/favicon-16.png" type="image/png" sizes="16x16">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <link rel="preload" href="/assets/fonts/hanken-grotesk-latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/bricolage-grotesque-latin.woff2" as="font" type="font/woff2" crossorigin>
  <style>{% set inlineCss %}{% include "css/fonts.css" %}{% include "css/style.css" %}{% endset %}{{ inlineCss | cssmin | safe }}</style>

  <!-- Structured data: the artist as a person and a local service business -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "{{ site.url }}/#chris-carlson",
        "name": "{{ site.author }}",
        "jobTitle": "{{ site.jobTitle }}",
        "url": "{{ site.url }}",
        "email": "mailto:{{ site.email }}",
        "image": "{{ '/assets/img/site/chris-carlson-portrait.jpg' | absoluteUrl(site.url) }}",
        "sameAs": [
          "{{ site.social.instagram }}",
          "{{ site.social.facebook }}",
          "{{ site.social.etsy }}"
        ]
      },
      {
        "@type": "ProfessionalService",
        "@id": "{{ site.url }}/#business",
        "name": "{{ site.name }}",
        "description": "{{ site.description }}",
        "url": "{{ site.url }}",
        "image": "{{ ogImg }}",
        "email": "mailto:{{ site.email }}",
        "founder": { "@id": "{{ site.url }}/#chris-carlson" },
        "priceRange": "$$$",
        "areaServed": "Worldwide",
        "knowsAbout": ["3D chalk art", "3D chalk artist", "mural art", "3D mural artist", "anamorphic street painting", "interactive murals"],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Commissioned artwork",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "3D Chalk Art",
                "description": "Anamorphic 3D chalk art and street paintings created live at festivals, events, and brand activations.",
                "url": "{{ site.url }}/3d-chalk-art/"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "3D Murals",
                "description": "Permanent 3D murals and interactive wall-and-floor illusions for museums, dealerships, offices, and brand spaces.",
                "url": "{{ site.url }}/3d-murals/"
              }
            }
          ]
        },
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "{{ site.location.city }}",
          "addressRegion": "{{ site.location.region }}",
          "addressCountry": "{{ site.location.country }}"
        },
        "sameAs": [
          "{{ site.social.instagram }}",
          "{{ site.social.facebook }}",
          "{{ site.social.etsy }}"
        ]
      }
    ]
  }
  </script>

  {%- if page.url and page.url != "/" %}
  <!-- Breadcrumb trail for search results -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/" }
      {%- if "/blog/" in page.url and page.url != "/blog/" -%}
      ,{ "@type": "ListItem", "position": 2, "name": "Blog", "item": "{{ site.url }}/blog/" },
      { "@type": "ListItem", "position": 3, "name": "{{ title }}", "item": "{{ canonical }}" }
      {%- else -%}
      ,{ "@type": "ListItem", "position": 2, "name": "{{ title if title else site.name }}", "item": "{{ canonical }}" }
      {%- endif %}
    ]
  }
  </script>
  {%- endif %}
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  {% include "partials/header.njk" %}
  <main id="main">
    {{ content | safe }}
  </main>
  {% include "partials/footer.njk" %}
  <script src="/assets/js/main.js" defer></script>
</body>
</html>
